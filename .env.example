# Copy this file to `.env` and fill in your credentials.
# The codebase loads `./.env` via `python-dotenv`.

# Weights & Biases (wandb) API key
WANDB_API_KEY=YOUR_WANDB_API_KEY

# Hugging Face access token
HF_TOKEN=YOUR_HF_TOKEN

# Groq API key (used by evaluation LLM routing when configured)
GROQ_API_KEY=YOUR_GROQ_API_KEY

# OpenAI API key (used for direct OpenAI calls)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Optional: override the model identifier used for both Groq/OpenAI calls.
# Examples (edit as desired):
# LLM_MODEL=gpt-5.4-mini
LLM_MODEL=
